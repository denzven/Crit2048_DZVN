{
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "platforms": [
    "windows",
    "android"
  ],
  "permissions": [
    "core:default",
    "haptics:default",
    "haptics:allow-vibrate",
    "haptics:allow-impact-feedback",
    "haptics:allow-notification-feedback",
    "haptics:allow-selection-feedback",
    "fs:default",
    "core:path:default",
    "share:default",
    "share:allow-share-file",
    "opener:default",
    "dialog:default",
    "http:default",
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$CACHE/**" },
        { "path": "$EXTERNAL_CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURES/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/**" },
        { "path": "$APP_DATA/**" },
        { "path": "$APP_LOCAL_DATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$CACHE/**" },
        { "path": "$EXTERNAL_CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURES/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/**" },
        { "path": "$APP_DATA/**" },
        { "path": "$APP_LOCAL_DATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$CACHE/**" },
        { "path": "$EXTERNAL_CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURES/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/**" },
        { "path": "$APP_DATA/**" },
        { "path": "$APP_LOCAL_DATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$CACHE/**" },
        { "path": "$EXTERNAL_CACHE/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$PICTURES/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$HOME/**" },
        { "path": "$APP_DATA/**" },
        { "path": "$APP_LOCAL_DATA/**" }
      ]
    },
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    }
  ]
}
