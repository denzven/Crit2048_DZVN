{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Crit2048",
  "version": "1.3.0",
  "identifier": "com.crit2048.app",
  "build": {
    "frontendDist": "../.web-build",
    "beforeDevCommand": "npm run prebuild",
    "beforeBuildCommand": "npm run prebuild"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Crit2048",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
