{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crit 2048",
  "version": "1.0.0",
  "identifier": "com.dzvn.crit2048",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Crit 2048 — Roguelike D&D",
        "width": 430,
        "height": 932,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 DZVN",
    "category": "Game",
    "shortDescription": "A roguelike 2048 dungeon crawler inspired by Balatro and D&D 5e",
    "longDescription": "Crit 2048 is a roguelike dungeon crawler built on the 2048 sliding puzzle. Fight six bosses, cast spells, roll d20s, and collect artifacts in this Balatro-inspired D&D experience.",
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": ""
    },
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
